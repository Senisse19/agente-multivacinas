# ──────────────────────────────────────────────
#  MultiVacinas — Variáveis de Ambiente
#  Copie para .env e preencha os valores reais.
#  NUNCA suba o .env para o git.
# ──────────────────────────────────────────────

# ─── Chatwoot ──────────────────────────────────
# URL da sua instância Chatwoot (sem barra no final)
CHATWOOT_BASE_URL=https://chat.suaempresa.com.br

# User Access Token: Chatwoot → Perfil → Access Token
CHATWOOT_API_TOKEN=seu_token_aqui

# ID numérico da conta (aparece na URL do Chatwoot: /app/accounts/1/...)
CHATWOOT_ACCOUNT_ID=1

# ID do time humano para receber handovers (opcional — deixe em branco se não usar times)
CHATWOOT_TEAM_ID=

# IDs das Inboxes (Chatwoot → Settings → Inboxes → clique na inbox → veja a URL)
CHATWOOT_INBOX_LOJA1_ID=1
CHATWOOT_INBOX_LOJA2_ID=2

# ─── OpenClaw ──────────────────────────────────
# URL interna do serviço OpenClaw no Coolify
# Se bridge e openclaw estão no mesmo projeto Coolify: http://openclaw:18789
# Se em projetos separados: use o IP interno ou a URL pública com token
OPENCLAW_GATEWAY_URL=http://openclaw:18789

# Token de autenticação do gateway (mesmo valor em openclaw.config.json → gateway.auth.token)
OPENCLAW_GATEWAY_TOKEN=seu_token_openclaw_aqui

# ─── Bridge ────────────────────────────────────
# Porta em que a bridge vai escutar (o Chatwoot vai fazer POST nessa URL)
PORT=3001
