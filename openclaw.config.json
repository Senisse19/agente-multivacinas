// CONFIGURAÇÃO DO GATEWAY OPENCLAW — MultiVacinas
// ================================================
// Este arquivo vai para: OPENCLAW_CONFIG_DIR/openclaw.json
// No container Docker padrão: /home/node/.openclaw/openclaw.json
//
// Documentação: https://docs.openclaw.ai/gateway/configuration
{
  agents: {
    defaults: {
      // Caminho do workspace DENTRO do container Docker
      // O Coolify monta o volume do projeto aqui via OPENCLAW_WORKSPACE_DIR
      workspace: "/home/node/.openclaw/workspace",

      model: {
        primary: "anthropic/claude-opus-4-6",
        fallbacks: ["anthropic/claude-sonnet-4-6"],
      },

    },
  },

  gateway: {
    port: 18789,

    // "lan" obrigatório no Docker para a bridge conseguir se conectar
    bind: "lan",

    // Token lido da variável de ambiente OPENCLAW_GATEWAY_TOKEN (configurada no Coolify)
    auth: {},

    controlUi: {
      allowedOrigins: [
        "https://openclaw.multivacinas.com.br",
        "http://localhost:18789",
      ],
    },

    reload: {
      mode: "hybrid",
    },
  },
}
